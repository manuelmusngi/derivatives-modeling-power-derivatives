# 02 — Calibrate OU models
# This notebook calibrates the Lucia–Schwartz one-factor OU (with seasonality) and a practical two-factor decomposition using Polars for ETL and NumPy for estimation. Outputs calibrated parameters and diagnostics.

# Imports and config
import yaml
import polars as pl
import numpy as np
from pathlib import Path
import matplotlib.pyplot as plt

from src.electricity_models.calibration import deseasonalize_log_spot, estimate_ou_mle, estimate_two_factor_cov
from src.electricity_models.diagnostics import residuals_ar1, summary_params
from src.electricity_models.viz import plot_deseasonalized

with open("config/settings.yaml", "r") as f:
    config = yaml.safe_load(f)

data_path = Path(config["paths"]["interim_dir"]) / "spot_with_seasonality.csv"
spot = pl.read_csv(data_path, try_parse_dates=True)
spot = spot.with_columns(pl.col("date").cast(pl.Date)).sort("date")

spot.select(["date", "spot", "log_spot", "s_t"]).head(5)

# Train window selection
train_start = pl.datetime.strptime(config["calibration"]["train_start"], "%Y-%m-%d")
train_end = pl.datetime.strptime(config["calibration"]["train_end"], "%Y-%m-%d")

spot_train = spot.filter((pl.col("date") >= pl.Date(config["calibration"]["train_start"])) &
                         (pl.col("date") <= pl.Date(config["calibration"]["train_end"])))

print(spot_train.head(5))
print(f"Train rows: {spot_train.height}")


# Deseasonalize and visualize
x = deseasonalize_log_spot(spot_train, season_col="s_t")
plot_deseasonalized(spot_train)
plt.show()

dt = 1.0 / 365.0

# One-factor OU calibration via AR(1) mapping (exact OU discretization)
ou_params = estimate_ou_mle(x, dt)
df_params_ou = summary_params(ou_params)
df_params_ou


# Diagnostics — AR(1) residuals
df_resid = residuals_ar1(spot_train, x_col="log_spot")  # uses log spot; close proxy
fig, ax = plt.subplots(figsize=(10,4))
ax.plot(df_resid["t"], df_resid["resid"], lw=0.8, color="gray")
ax.set_title("AR(1) residuals on log spot (proxy)")
ax.axhline(0, color="black", lw=0.5)
plt.show()


# Two-factor heuristic calibration (fast vs slow components)
tf_params = estimate_two_factor_cov(spot_train, season_col="s_t", fast_window=7, slow_window=90, dt=dt)
df_params_tf = summary_params(tf_params)
df_params_tf


# Save calibrated parameters
processed_dir = Path(config["paths"]["processed_dir"])
processed_dir.mkdir(parents=True, exist_ok=True)

# Save to YAML for reuse in pricing
params_yaml = {
    "one_factor": {k: float(v) for k, v in ou_params.items()},
    "two_factor": {k: float(v) for k, v in tf_params.items()},
    "dt": dt,
    "train_window": {
        "start": config["calibration"]["train_start"],
        "end": config["calibration"]["train_end"],
    }
}
with open(processed_dir / "calibrated_params.yaml", "w") as f:
    yaml.safe_dump(params_yaml, f)

print("Saved:", processed_dir / "calibrated_params.yaml")




















