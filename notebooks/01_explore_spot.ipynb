# 01 — Explore spot data
# This notebook loads MISO/Nord Pool spot data, performs basic cleaning, constructs seasonality features using Polars, and produces exploratory visuals. It saves interim cleaned datasets for downstream calibration.

# Imports and configuration
import yaml
import polars as pl
from pathlib import Path
import matplotlib.pyplot as plt

from src.electricity_models.io import read_spot, write_df
from src.electricity_models.cleaning import clip_outliers, add_log_spot
from src.electricity_models.features import add_sinusoidal_seasonality, fit_seasonality_ols, apply_seasonality
from src.electricity_models.viz import plot_spot, plot_deseasonalized

with open("config/settings.yaml", "r") as f:
    config = yaml.safe_load(f)

config

# Load raw spot and basic checks
spot = read_spot(
    path=config["paths"]["raw_spot"],
    date_col=config["data"]["date_col"],
    spot_col=config["data"]["spot_col"],
)

print(spot.head(5))
print(spot.describe())
print(f"Rows: {spot.height}, Columns: {spot.width}")

# Clean outliers and log-transform
spot_clean = clip_outliers(spot, col="spot", p_low=0.01, p_high=0.99)
spot_clean = add_log_spot(spot_clean)

plot_spot(spot_clean)
plt.show()

spot_clean.head(5)

# Add seasonality features (sinusoidal + weekly dummies)
spot_feats = add_sinusoidal_seasonality(
    spot_clean,
    freq_per_year=config["seasonality"]["frequency_per_year"],
    include_weekly=config["seasonality"]["include_weekly"],
)
feat_cols = [c for c in spot_feats.columns if c.startswith(("cos_", "sin_", "dow_"))]
print(f"Seasonality features: {feat_cols[:6]} ... total {len(feat_cols)}")

spot_feats.head(5)

# Fit seasonality model via OLS
s_model = fit_seasonality_ols(spot_feats, target_col="log_spot", feature_cols=feat_cols)
spot_seas = apply_seasonality(spot_feats, s_model, as_col="s_t")

spot_seas.select(["date", "spot", "log_spot", "s_t"]).head(5)


# Visualize deseasonalized log spot
plot_deseasonalized(spot_seas)
plt.show()


# Save interim data and seasonality model summary
interim_path = Path(config["paths"]["interim_dir"])
interim_path.mkdir(parents=True, exist_ok=True)

write_df(spot_seas, interim_path / "spot_with_seasonality.csv")

# Save seasonality coefficients to YAML for reproducibility
seas_model_yaml = {
    "intercept": float(s_model["intercept"]),
    "feature_cols": s_model["feature_cols"],
    "betas": {k: float(v) for k, v in s_model["betas"].items()},
}
with open(interim_path / "seasonality_model.yaml", "w") as f:
    yaml.safe_dump(seas_model_yaml, f)

print("Saved:", interim_path / "spot_with_seasonality.csv")
print("Saved:", interim_path / "seasonality_model.yaml")


